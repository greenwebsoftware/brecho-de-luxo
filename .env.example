# ============================================================
# Brecho de Luxo - Variaveis de Ambiente
# Renomeie para .env.local e preencha os valores
# ============================================================

# Supabase do cliente Brecho de Luxo (mesmo do ModaSystem)
NEXT_PUBLIC_SUPABASE_URL=https://SUPABASE_DO_BRECHO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# URL do site (para webhooks e redirecionamentos)
NEXT_PUBLIC_SITE_URL=https://brechodeluxo.com.br

# Mercado Pago
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# PayPal (opcional)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# PagarMe (opcional)
PAGARME_API_KEY=

# Email (para notificacoes de pedidos)
EMAIL_FROM=contato@brechodeluxo.com.br
EMAIL_RESEND_KEY=
REBUILT=true 
